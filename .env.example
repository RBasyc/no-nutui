# 环境变量配置模板
# 复制此文件为 .env.local 并填入真实值
# ⚠️ 注意：.env.local 文件已在 .gitignore 中排除，不会提交到 Git

# 后端服务地址 (端口 3000) - 主要业务接口
VITE_BACKEND_BASE_URL=http://localhost:3000

# MCP 服务地址 (端口 3001) - AI 工具接口
VITE_MCP_BASE_URL=http://localhost:3001

# 兼容旧配置（统一使用 BACKEND_BASE_URL）
VITE_API_BASE_URL=http://localhost:3000

# 微信小程序 AppID
# 获取方式：微信公众平台 -> 开发 -> 开发设置 -> 开发者ID
TARO_APP_ID=wxXXXXXXXXXXXXXXXX

# 生产环境配置示例
# VITE_BACKEND_BASE_URL=https://your-production-api.com
# VITE_MCP_BASE_URL=https://your-production-mcp.com
# VITE_API_BASE_URL=https://your-production-api.com
# TARO_APP_ID=wxXXXXXXXXXXXXXXXX

# 其他可选配置
# VITE_APP_NAME=实验室库存管理系统
# VITE_APP_VERSION=1.0.0
